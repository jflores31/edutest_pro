# ── Django ────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets,string; print(''.join(secrets.choice(string.ascii_letters+string.digits+'!@#$%^&*(-_=+)') for _ in range(64)))"
SECRET_KEY=change-me-generate-a-real-64-char-secret-key
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com

# ── Security ──────────────────────────────────────────────────────────────────
# In production (Render): set SECURE_PROXY_SSL_HEADER=True so cookies get the Secure
# flag behind the TLS-terminating proxy, and turn the rest on.
SECURE_PROXY_SSL_HEADER=False
SECURE_SSL_REDIRECT=False
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
CSRF_TRUSTED_ORIGINS=http://localhost,http://127.0.0.1   # prod: https://your-app.vercel.app

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Local dev: the docker-compose values below.
# Supabase (prod): use the connection pooler — host ...pooler.supabase.com, port 6543,
# and POSTGRES_SSLMODE=require.
POSTGRES_DB=edutest
POSTGRES_USER=edutest
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_SSLMODE=                                          # prod (Supabase): require

# ── Redis (cache, heartbeat, rate-limit, revoked tokens) ───────────────────────
# Local dev: docker redis. Prod: Upstash rediss:// URL (TLS).
REDIS_PASSWORD=change-me-redis-password
CACHE_URL=redis://:change-me-redis-password@redis:6379/2   # prod: rediss://default:<pwd>@<host>.upstash.io:6379

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=https://yourdomain.com

# ── Nginx ─────────────────────────────────────────────────────────────────────
NGINX_PORT=80

# ── Django settings module ────────────────────────────────────────────────────
DJANGO_SETTINGS_MODULE=config.settings

# ── Sentry (opcional — dejar vacío para deshabilitar) ─────────────────────────
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
VITE_SENTRY_DSN=
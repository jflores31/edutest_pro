# ── Django ────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets,string; print(''.join(secrets.choice(string.ascii_letters+string.digits+'!@#$%^&*(-_=+)') for _ in range(64)))"
SECRET_KEY=change-me-generate-a-real-64-char-secret-key
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com

# ── Security ──────────────────────────────────────────────────────────────────
SECURE_SSL_REDIRECT=False
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
CSRF_TRUSTED_ORIGINS=http://localhost,http://127.0.0.1

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=edutest
POSTGRES_USER=edutest
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql://edutest:change-me-strong-password@postgres:5432/edutest

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=change-me-redis-password
CELERY_BROKER_URL=redis://:change-me-redis-password@redis:6379/0
CELERY_RESULT_BACKEND=redis://:change-me-redis-password@redis:6379/1
CACHE_URL=redis://:change-me-redis-password@redis:6379/2

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=https://yourdomain.com

# ── Nginx ─────────────────────────────────────────────────────────────────────
NGINX_PORT=80

# ── Django settings module ────────────────────────────────────────────────────
DJANGO_SETTINGS_MODULE=config.settings

# ── Sentry (opcional — dejar vacío para deshabilitar) ─────────────────────────
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
VITE_SENTRY_DSN=